# ============================================
# Mc-EasyPanel 环境变量配置
# 复制此文件为 .env 并修改生产环境的密钥
# ============================================

# 运行模式：true=开发模式（宽松 CORS/CSP），false=生产模式（严格安全策略）
DEV_MODE=true

# 面板监听端口（容器内，docker-compose 已映射为 3301）
SERVER_PORT=3001

# JWT 签名密钥（必填！生产环境必须修改为一个复杂随机字符串）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your-strong-random-secret-here
